#include<stdio.h>
 int main()
 {
     int i,j,count=0,element,a[3][3];
      
      printf("Enter the 3*3 matrix\n");
       
       for(i=0;i<3;i++){
           for(j=0;j<3;j++){
               scanf("%d",&a[i][j]);
           }
       }
       printf("Enter element to find the frequency of a matrix:");
       scanf("%d",&element);
        
        
        for(i=0;i<3;i++){
            for(j=0;j<3;j++){
                if(a[i][j]==element){
                    count=count+1;
                }
            }
        }
        printf("the fequency of %d=%d", element,count);
 return 0;
 }
     
