#include <stdio.h>

int main()
{
    int binary=0, decimal=0,base=1, remainder;
    
    printf("Enter a decimal number:");
    scanf("%d",&decimal);

    
        while(decimal>0){
    remainder =decimal % 2;
    binary=remainder*base;
    decimal=decimal/2;
    base=base*10;
    }
    printf("binary=%d\n",binary);
    
return 0;
}
    
   
